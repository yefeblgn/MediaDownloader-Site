# BLGNTube ortam değişkenleri
# Bu dosyayı ".env" adıyla kopyalayın ve değerleri kendi bilgilerinizle doldurun:
#   cp .env.example .env
# .env dosyası git'e EKLENMEZ (gizli bilgiler içerir).

# --- Google ile Giriş (OAuth 2.0) ---
# https://console.cloud.google.com/apis/credentials adresinden "OAuth client ID"
# oluşturun (Application type: Web application).
# Yetkili yönlendirme URI'si olarak şunu ekleyin:
#   https://localhost:7080/signin-google
#   http://localhost:5080/signin-google
# Boş bırakırsanız Google girişi devre dışı kalır (site yine çalışır).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Yönetici (Admin) hesabı ---
# Uygulama ilk açılışta bu hesabı oluşturur ve "Admin" rolü verir.
# Bu bilgilerle giriş yapıp /admin paneline erişebilirsiniz.
ADMIN_EMAIL=admin@blgntube.local
ADMIN_PASSWORD=Admin123!

# --- Varsayılan dil ---
# tr veya en
DEFAULT_CULTURE=tr
