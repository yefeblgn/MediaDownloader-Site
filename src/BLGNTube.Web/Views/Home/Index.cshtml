@{
    ViewData["Title"] = "Medya İndir";
    var remaining = (int)(ViewBag.Remaining ?? 0);
    var limit     = (int)(ViewBag.Limit ?? 0);
    var isAuth    = (bool)(ViewBag.IsAuthenticated ?? false);
}

<!-- Hero -->
<section class="hero-bg" style="padding:3.5rem 1.5rem 0;">
    <div class="hero-glow"></div>
    <div style="max-width:680px;margin:0 auto;text-align:center;padding-bottom:2.5rem;">
        <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:700;letter-spacing:-0.03em;line-height:1.15;margin:0 0 1rem;">
            @Loc["home.hero.pre"]<span style="color:var(--accent);">@Loc["home.hero.highlight"]</span>@Loc["home.hero.post"]
        </h1>
        <p style="font-size:1rem;color:var(--text2);margin:0;max-width:460px;margin-inline:auto;">
            @Loc["home.hero.subtitle"]
        </p>
    </div>
</section>

<!-- Kart -->
<section style="max-width:680px;margin:0 auto;padding:0 1.5rem 4rem;">

    <div class="card" style="padding:1.5rem;">

        @if (remaining <= 0)
        {
            <div style="margin-bottom:1rem;padding:0.625rem 0.875rem;border-radius:var(--radius);background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);color:#fca5a5;font-size:0.875rem;display:flex;align-items:center;justify-content:space-between;gap:0.75rem;">
                <span>Günlük indirme limitine ulaştın.</span>
                @if (!isAuth)
                {
                    <a asp-controller="Account" asp-action="Register" style="color:var(--accent);text-decoration:none;font-weight:600;white-space:nowrap;flex-shrink:0;">Hesap aç →</a>
                }
            </div>
        }
        <span id="quotaRemaining" style="display:none;">@remaining</span>

        <!-- URL input -->
        <div style="display:flex;gap:0.625rem;">
            <div style="position:relative;flex:1;">
                <svg style="position:absolute;left:0.875rem;top:50%;transform:translateY(-50%);pointer-events:none;" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <input id="urlInput" type="url" inputmode="url" autocomplete="off" spellcheck="false"
                       placeholder="@Loc["home.url.placeholder"]"
                       class="input" style="padding-left:2.5rem;" />
            </div>
            <button id="fetchBtn" type="button" class="btn btn-primary" style="flex-shrink:0;">
                <span class="btn-label">@Loc["home.fetch"]</span>
                <span class="btn-spinner" style="display:none;width:15px;height:15px;border:2px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;"></span>
            </button>
        </div>

        <!-- Hata kutusu -->
        <div id="errorBox" style="display:none;margin-top:0.75rem;padding:0.625rem 0.875rem;border-radius:var(--radius);background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);color:#fca5a5;font-size:0.875rem;"></div>

        <!-- Önizleme -->
        <div id="previewPanel" style="display:none;margin-top:1.25rem;">
            <div style="display:flex;gap:0.875rem;padding:0.875rem;border-radius:var(--radius);background:var(--surface2);border:1px solid var(--border);">
                <img id="thumb" alt="" style="width:112px;height:68px;object-fit:cover;border-radius:6px;background:var(--border);flex-shrink:0;" />
                <div style="min-width:0;flex:1;">
                    <p id="mediaTitle" style="font-weight:600;font-size:0.9375rem;margin:0 0 0.375rem;line-height:1.3;" class="line-clamp-2"></p>
                    <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
                        <span id="mediaSite" style="font-size:0.75rem;padding:0.15rem 0.5rem;border-radius:4px;background:var(--border);color:var(--text2);"></span>
                        <span id="mediaUploader" style="font-size:0.8125rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;"></span>
                        <span id="mediaDuration" style="font-size:0.8125rem;color:var(--text3);"></span>
                    </div>
                </div>
            </div>

            <!-- Format seçimi -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.625rem;margin-top:0.875rem;">
                <button type="button" data-format="mp4" class="fmt-btn format-btn is-active">
                    <span class="fmt-icon" style="color:var(--accent);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="m10 9 5 3-5 3z"/></svg>
                    </span>
                    <div>
                        <div style="font-weight:600;font-size:0.9rem;">@Loc["home.format.mp4"]</div>
                        <div style="font-size:0.75rem;color:var(--text2);">@Loc["home.format.mp4.sub"]</div>
                    </div>
                </button>
                <button type="button" data-format="mp3" class="fmt-btn format-btn">
                    <span class="fmt-icon" style="color:var(--text2);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                    </span>
                    <div>
                        <div style="font-weight:600;font-size:0.9rem;">@Loc["home.format.mp3"]</div>
                        <div style="font-size:0.75rem;color:var(--text2);">@Loc["home.format.mp3.sub"]</div>
                    </div>
                </button>
            </div>

            <!-- Kalite -->
            <div id="qualityWrap" style="margin-top:0.75rem;">
                <label style="font-size:0.8125rem;color:var(--text2);display:block;margin-bottom:0.375rem;">@Loc["home.quality.label"]</label>
                <select id="qualitySelect" class="input" style="cursor:pointer;"></select>
            </div>

            <button id="downloadBtn" type="button" class="btn btn-primary" style="width:100%;margin-top:1rem;padding:0.875rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 21h14"/></svg>
                @Loc["home.download"]
            </button>
        </div>

        <!-- İlerleme -->
        <div id="progressPanel" style="display:none;margin-top:1.25rem;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                <span id="progressLabel" style="font-size:0.875rem;color:var(--text2);">@Loc["home.progress.preparing"]</span>
                <span id="progressPct" style="font-size:0.875rem;font-weight:600;font-variant-numeric:tabular-nums;">0%</span>
            </div>
            <div style="height:4px;border-radius:9999px;background:var(--surface2);overflow:hidden;">
                <div id="progressBar" style="width:0%;"></div>
            </div>
        </div>

        <!-- Tamamlandı -->
        <div id="readyPanel" style="display:none;margin-top:1.25rem;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1rem;border-radius:var(--radius);background:rgba(34,197,94,0.07);border:1px solid rgba(34,197,94,0.2);">
                <div style="display:flex;align-items:center;gap:0.75rem;min-width:0;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M21.8 10A10 10 0 1 1 17 3.3"/><path d="m9 11 3 3L22 4"/></svg>
                    <div style="min-width:0;">
                        <div style="font-weight:600;font-size:0.9rem;color:#4ade80;">@Loc["home.ready.title"]</div>
                        <div id="readyMeta" style="font-size:0.8125rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
                    </div>
                </div>
                <a id="saveBtn" href="#"
                   style="flex-shrink:0;display:inline-flex;align-items:center;gap:0.375rem;padding:0.5rem 1rem;border-radius:var(--radius);background:#22c55e;color:#fff;font-weight:600;font-size:0.875rem;text-decoration:none;transition:background 0.15s;"
                   onmouseover="this.style.background='#16a34a'" onmouseout="this.style.background='#22c55e'">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 21h14"/></svg>
                    @Loc["home.ready.save"]
                </a>
            </div>
            <button id="resetBtn" type="button" class="btn btn-ghost" style="width:100%;margin-top:0.625rem;font-size:0.875rem;font-weight:400;">
                @Loc["home.ready.new"]
            </button>
        </div>

    </div>

    <!-- Özellikler -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:0.75rem;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;background:var(--border);">
        <div style="background:var(--surface);padding:1rem 1.125rem;">
            <div style="font-size:0.8125rem;font-weight:600;color:var(--text);margin-bottom:0.25rem;">@Loc["home.features.speed.title"]</div>
            <div style="font-size:0.75rem;color:var(--text2);line-height:1.4;">@Loc["home.features.speed.desc"]</div>
        </div>
        <div style="background:var(--surface);padding:1rem 1.125rem;">
            <div style="font-size:0.8125rem;font-weight:600;color:var(--text);margin-bottom:0.25rem;">@Loc["home.features.sites.title"]</div>
            <div style="font-size:0.75rem;color:var(--text2);line-height:1.4;">@Loc["home.features.sites.desc"]</div>
        </div>
        <div style="background:var(--surface);padding:1rem 1.125rem;">
            <div style="font-size:0.8125rem;font-weight:600;color:var(--text);margin-bottom:0.25rem;">@Loc["home.features.history.title"]</div>
            <div style="font-size:0.75rem;color:var(--text2);line-height:1.4;">@Loc["home.features.history.desc"]</div>
        </div>
    </div>

</section>

@section Scripts {
    <style>
        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
    <script>
        window.LOC = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, string> {
            ["starting"]    = Loc["js.starting"],
            ["downloading"] = Loc["js.downloading"],
            ["converting"]  = Loc["js.converting"],
            ["completed"]   = Loc["js.completed"],
            ["paste"]       = Loc["js.paste"],
            ["infoFailed"]  = Loc["js.info_failed"],
            ["startFailed"] = Loc["js.start_failed"],
            ["notFound"]    = Loc["js.not_found"],
            ["failed"]      = Loc["js.failed"]
        }));
    </script>
    <script src="~/js/download.js" asp-append-version="true"></script>
}
