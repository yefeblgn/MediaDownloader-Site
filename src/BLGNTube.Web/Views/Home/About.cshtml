@{
    ViewData["Title"] = "Nasıl Çalışır?";
}

<section class="max-w-3xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-center animate-fade-up">Nasıl çalışır?</h1>
    <p class="mt-3 text-center text-slate-400 animate-fade-up">Üç adımda yüksek kaliteli indirme.</p>

    <div class="mt-10 space-y-4">
        @{
            var steps = new (string n, string t, string d)[]
            {
                ("1", "Bağlantıyı yapıştır", "YouTube, TikTok, Twitter/X, Reddit ve yüzlerce siteden bir medya bağlantısını kopyala ve kutuya yapıştır."),
                ("2", "Format & kalite seç", "MP4 video (4K'ya kadar) veya MP3 ses (320 kbps) seç. Video için çözünürlüğü belirle."),
                ("3", "İndir", "Sunucu içeriği hazırlar, ilerlemeyi canlı izlersin ve dosya cihazına kaydedilir.")
            };
        }
        @foreach (var s in steps)
        {
            <div class="glass rounded-2xl p-6 flex gap-5 items-start animate-fade-up">
                <span class="grid place-items-center w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-fuchsia-500 font-display font-bold shrink-0">@s.n</span>
                <div>
                    <h3 class="font-semibold text-lg">@s.t</h3>
                    <p class="mt-1 text-slate-400 text-sm">@s.d</p>
                </div>
            </div>
        }
    </div>

    <div class="mt-8 glass rounded-2xl p-6 animate-fade-up">
        <h3 class="font-semibold text-lg">Günlük limitler</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-300">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span> Üye olmayanlar: <b class="text-white">günde 10 indirme</b> (IP başına).</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-400"></span> Ücretsiz üyeler: <b class="text-white">günde 100 indirme</b> + indirme geçmişi.</li>
        </ul>
    </div>

    <div class="mt-8 text-center animate-fade-up">
        <a asp-controller="Home" asp-action="Index" class="inline-block px-6 py-3 rounded-xl font-semibold bg-gradient-to-r from-brand-500 to-fuchsia-500 hover:from-brand-600 hover:to-fuchsia-600 shadow-lg shadow-brand-500/30 transition">Hemen indirmeye başla</a>
    </div>

    <p class="mt-8 text-xs text-center text-slate-500">
        BLGNTube eğitim amaçlı bir projedir ve açık kaynaklı yt-dlp motorunu kullanır.
        Yalnızca yasal olarak indirme hakkına sahip olduğunuz içerikleri indirin.
    </p>
</section>
