@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var isSignedIn = SignInManager.IsSignedIn(User);
    var displayName = isSignedIn ? (await UserManager.GetUserAsync(User))?.DisplayName : null;
}
<!DOCTYPE html>
<html lang="tr" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BLGNTube</title>
    <meta name="description" content="BLGNTube — YouTube, TikTok, Twitter, Reddit ve yüzlerce siteden MP3/MP4 medya indirme aracı." />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Poppins', 'system-ui', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#fff1f2', 100: '#ffe4e6', 400: '#fb7185',
                            500: '#f43f5e', 600: '#e11d48', 700: '#be123c',
                        },
                    },
                    keyframes: {
                        'fade-up': { '0%': { opacity: 0, transform: 'translateY(16px)' }, '100%': { opacity: 1, transform: 'translateY(0)' } },
                        'float': { '0%,100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-10px)' } },
                    },
                    animation: {
                        'fade-up': 'fade-up .6s ease-out both',
                        'float': 'float 6s ease-in-out infinite',
                    },
                },
            },
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-[#0b0b14] text-slate-100 font-sans antialiased min-h-screen flex flex-col overflow-x-hidden">

    <!-- Animasyonlu gradient arka plan -->
    <div class="aurora" aria-hidden="true">
        <span class="blob blob-1"></span>
        <span class="blob blob-2"></span>
        <span class="blob blob-3"></span>
    </div>

    <header class="sticky top-0 z-40">
        <nav class="backdrop-blur-xl bg-white/5 border-b border-white/10">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 group">
                    <span class="grid place-items-center w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-fuchsia-500 shadow-lg shadow-brand-500/30 group-hover:scale-105 transition-transform">
                        <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 21h14"/></svg>
                    </span>
                    <span class="font-display font-extrabold text-xl tracking-tight">BLGN<span class="text-brand-500">Tube</span></span>
                </a>

                <div class="flex items-center gap-2 sm:gap-3">
                    <a asp-controller="Home" asp-action="About" class="hidden sm:inline-block px-3 py-2 text-sm text-slate-300 hover:text-white transition">Nasıl Çalışır?</a>
                    @if (isSignedIn)
                    {
                        <a asp-controller="Profile" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium bg-white/5 hover:bg-white/10 border border-white/10 transition flex items-center gap-2">
                            <svg class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                            <span class="max-w-[8rem] truncate">@displayName</span>
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="px-3 py-2 rounded-lg text-sm text-slate-300 hover:text-white hover:bg-white/5 transition">Çıkış</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="px-3 py-2 rounded-lg text-sm text-slate-200 hover:text-white transition">Giriş</a>
                        <a asp-controller="Account" asp-action="Register" class="px-4 py-2 rounded-lg text-sm font-semibold bg-gradient-to-r from-brand-500 to-fuchsia-500 hover:from-brand-600 hover:to-fuchsia-600 shadow-lg shadow-brand-500/30 transition">Kayıt Ol</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-1 relative z-10">
        @RenderBody()
    </main>

    <footer class="relative z-10 border-t border-white/10 mt-16">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-400">
            <p>© @DateTime.Now.Year <span class="font-display font-bold text-slate-200">BLGNTube</span> — Eğitim amaçlı proje.</p>
            <p class="text-center sm:text-right">Yalnızca telif hakkına sahip olduğunuz / izinli içerikleri indirin.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
