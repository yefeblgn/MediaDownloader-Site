@model RegisterViewModel
@{
    ViewData["Title"] = Loc["auth.register.submit"];
    var externalSchemes = ViewData["ExternalSchemes"] as List<AuthenticationScheme> ?? new();
}

<section style="max-width:400px;margin:0 auto;padding:3rem 1.5rem 4rem;">

    <div style="text-align:center;margin-bottom:2rem;">
        <h1 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin:0 0 0.375rem;">@Loc["auth.register.title"]</h1>
        <p style="font-size:0.875rem;color:var(--text2);margin:0;">@Loc["auth.register.subtitle"]</p>
    </div>

    <div class="card" style="padding:1.75rem;">

        @if (externalSchemes.Any())
        {
            <form asp-controller="Account" asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @foreach (var scheme in externalSchemes)
                {
                    <button type="submit" name="provider" value="@scheme.Name" class="btn btn-white" style="width:100%;margin-bottom:0.5rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z"/><path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84z"/><path fill="#EA4335" d="M12 4.75c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 1.47 14.97.5 12 .5A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 4.75 12 4.75z"/></svg>
                        @Loc["auth.google"]
                    </button>
                }
            </form>
            <div class="divider" style="margin:1.25rem 0;">@Loc["auth.or"]</div>
        }

        <form asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" style="display:flex;flex-direction:column;gap:1rem;">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div>
                <label asp-for="DisplayName" style="font-size:0.8125rem;color:var(--text2);display:block;margin-bottom:0.375rem;">@Loc["auth.field.displayname"]</label>
                <input asp-for="DisplayName" autocomplete="nickname" class="input" />
                <span asp-validation-for="DisplayName"></span>
            </div>

            <div>
                <label asp-for="Email" style="font-size:0.8125rem;color:var(--text2);display:block;margin-bottom:0.375rem;">@Loc["auth.field.email"]</label>
                <input asp-for="Email" autocomplete="email" class="input" />
                <span asp-validation-for="Email"></span>
            </div>

            <div>
                <label asp-for="Password" style="font-size:0.8125rem;color:var(--text2);display:block;margin-bottom:0.375rem;">@Loc["auth.field.password"]</label>
                <input asp-for="Password" autocomplete="new-password" class="input" />
                <span asp-validation-for="Password"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" style="font-size:0.8125rem;color:var(--text2);display:block;margin-bottom:0.375rem;">@Loc["auth.field.confirm"]</label>
                <input asp-for="ConfirmPassword" autocomplete="new-password" class="input" />
                <span asp-validation-for="ConfirmPassword"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;padding:0.8125rem;">
                @Loc["auth.register.submit"]
            </button>
        </form>

        <p style="margin-top:1.25rem;text-align:center;font-size:0.875rem;color:var(--text2);">
            @Loc["auth.register.have_account"]
            <a asp-controller="Account" asp-action="Login" style="color:var(--accent);text-decoration:none;font-weight:500;">@Loc["auth.login.link"]</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
